          <mxGeometry x="380" y="770" width="250" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="flow_summary" value="1. Network Packet → Scapy → BPF Filter → Parser → PacketEvent → Queue&#xa;&#xa;2. Queue → Rate Engine (7 types) → Signals&#xa;   Queue → YARA Engine (signatures) → Signals&#xa;   Queue → Reputation Engine (AbuseIPDB) → Signals&#xa;&#xa;3. Signals → Deduplication (300s window) → Score Calculator → Severity Mapper → Alert&#xa;&#xa;4. Alert → SQLite (alerts table) → Query Builder → API Server&#xa;&#xa;5. API Server → REST (/alerts, /stats, /metrics) + WebSocket (/ws/alerts)&#xa;&#xa;6. Dashboard → React UI with real-time updates via WebSocket" style="text;html=1;strokeColor=#666666;fillColor=#f9f9f9;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;spacingLeft=10;spacingRight=10;spacingTop=8;spacingBottom=8" vertex="1" parent="1">
